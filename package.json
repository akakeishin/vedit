{
  "name": "vedit",
  "version": "0.1.0",
  "description": "AI-directed, non-destructive local video editing CLI and web NLE",
  "main": "./dist/cli.js",
  "homepage": "https://github.com/akakeishin/vedit#readme",
  "bugs": {
    "url": "https://github.com/akakeishin/vedit/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/akakeishin/vedit.git"
  },
  "files": [
    "bin/",
    "dist/",
    "web/aiRequestLogic.js",
    "web/app.js",
    "web/concurrencyLogic.js",
    "web/dragLogic.js",
    "web/historyLogic.js",
    "web/index.html",
    "web/ingestLogic.js",
    "web/mediaScaleLogic.js",
    "web/transcribeJobLogic.js",
    "web/style.css",
    "skill/",
    "scripts/install-agent-skills.mjs"
  ],
  "directories": {
    "doc": "docs"
  },
  "scripts": {
    "test": "vitest",
    "build": "tsc -p .",
    "prepack": "npm run build",
    "verify:dist": "npm run build && node scripts/verify-dist.mjs",
    "verify:package": "npm run build && node scripts/verify-package.mjs",
    "verify:install": "npm run build && node scripts/verify-install.mjs",
    "smoke:export": "node scripts/smoke-export.mjs",
    "smoke:compose": "npm run build && node scripts/smoke-compose.mjs",
    "smoke:overlay": "node scripts/smoke-overlay-stack.mjs",
    "test:e2e": "playwright test"
  },
  "keywords": [
    "video-editor",
    "nle",
    "ai",
    "codex",
    "claude-code",
    "ffmpeg"
  ],
  "author": "akakeishin",
  "license": "ISC",
  "engines": {
    "node": ">=20"
  },
  "type": "module",
  "bin": {
    "vedit": "./bin/vedit.js",
    "vedit-install-skills": "./scripts/install-agent-skills.mjs"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/node": "^26.1.1",
    "@types/ws": "^8.18.1",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "dependencies": {
    "ws": "^8.21.1"
  }
}
